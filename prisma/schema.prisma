generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model USER_INFO {
  USER_ID   String  @id @db.VarChar(20)
  PASSWORD  String  @db.VarChar(255)
  NAME      String  @db.VarChar(50)
  DEPT_NAME String  @db.VarChar(100)
  USER_ROLE String  @db.VarChar(20)
  STATUS    String  @db.VarChar(10)

  inspections DAILY_INSPECTION[] @relation("InspectionWriter")

  @@index([NAME], name: "IX_USER_NAME")
  @@map("USER_INFO")
}

model LAB_INFO {
  LAB_ID      String    @id @db.VarChar(20)
  LAB_NAME    String    @unique @db.VarChar(100)
  LOCATION    String    @db.VarChar(200)
  LAB_TYPE    String    @db.VarChar(50)
  CONTACT     String?   @db.VarChar(50)
  MGMT_LEVEL  String    @db.VarChar(20)
  SAFETY_SIGN String?   @db.VarChar(255)
  LAYOUT_IMG  String?   @db.VarChar(255)
  PHOTO       String?   @db.VarChar(255)
  ORG_ID      String    @db.VarChar(20)
  CREATED_AT  DateTime  @default(now())
  UPDATED_AT  DateTime? @updatedAt

  wasteRequests WASTE_REQUEST[]
  inspections   DAILY_INSPECTION[]

  @@index([LAB_TYPE],   name: "IDX_LAB_TYPE")
  @@index([MGMT_LEVEL], name: "IDX_LAB_MGMT")
  @@map("LAB_INFO")
}

model TB_CHEMICAL {
  CHEMICAL_ID      String @id @db.VarChar(30)
  PRODUCT_NAME     String @db.VarChar(200)
  MANUFACTURER     String @db.VarChar(100)
  CAS_NO           String @unique @db.VarChar(20)
  STORAGE_LOCATION String @db.VarChar(200)
  STATUS           String @db.VarChar(20)

  @@index([PRODUCT_NAME, CAS_NO, STORAGE_LOCATION], name: "IX_CH_SEARCH")
  @@map("TB_CHEMICAL")
}

model WASTE_REQUEST {
  REQUEST_ID       BigInt   @id @default(autoincrement())
  LABORATORY_ID    String   @db.VarChar(20)
  WASTE_TYPE       String   @db.VarChar(50)
  EMISSION_AMOUNT  Decimal  @db.Decimal(10, 3)
  EMISSION_DATE    DateTime @db.Date
  STORAGE_LOCATION String   @db.VarChar(100)
  REQUEST_REASON   String?  @db.Text
  REQUEST_STATUS   String   @db.VarChar(20)
  REQUEST_DATETIME DateTime @default(now())

  laboratory LAB_INFO @relation(fields: [LABORATORY_ID], references: [LAB_ID])

  @@unique([LABORATORY_ID, WASTE_TYPE, EMISSION_DATE], name: "UQ_WR_DUP")
  @@index([LABORATORY_ID, REQUEST_STATUS], name: "IX_WR_STATUS")
  @@index([EMISSION_DATE],                 name: "IX_WR_DATE")
  @@map("WASTE_REQUEST")
}

model DAILY_INSPECTION {
  INSPECTION_ID     BigInt    @id @default(autoincrement())
  LABORATORY_ID     String    @db.VarChar(20)
  INSPECTION_DATE   DateTime  @db.Date
  INSPECTION_METHOD String    @db.VarChar(20)
  CHECKLIST_RESULT  String    @db.Text
  NONCONFORM_REASON String?   @db.Text
  SPECIAL_NOTE      String?   @db.Text
  INSPECTION_STATUS String    @db.VarChar(20)
  WRITER_ID         String    @db.VarChar(20)
  SUBMIT_DATETIME   DateTime?
  CONFIRM_DATETIME  DateTime?

  laboratory LAB_INFO  @relation(fields: [LABORATORY_ID], references: [LAB_ID])
  writer     USER_INFO @relation("InspectionWriter", fields: [WRITER_ID], references: [USER_ID])

  @@unique([LABORATORY_ID, INSPECTION_DATE], name: "UQ_DI_DUP")
  @@index([LABORATORY_ID, INSPECTION_STATUS], name: "IX_DI_STATUS")
  @@index([INSPECTION_DATE],                  name: "IX_DI_DATE")
  @@map("DAILY_INSPECTION")
}

model EDUCATION_COURSE {
  COURSE_ID           BigInt   @id @default(autoincrement())
  COURSE_NAME         String   @unique @db.VarChar(100)
  EDUCATION_TYPE      String   @db.VarChar(50)
  TARGET_ROLE         String   @db.VarChar(50)
  COMPLETION_STANDARD String   @db.VarChar(100)
  START_DATE          DateTime @db.Date
  END_DATE            DateTime @db.Date
  CONTENT_PATH        String?  @db.VarChar(255)
  COURSE_STATUS       String   @db.VarChar(20)

  @@index([EDUCATION_TYPE, TARGET_ROLE], name: "IX_EC_TYPE_TARGET")
  @@index([START_DATE, END_DATE],        name: "IX_EC_PERIOD")
  @@index([COURSE_STATUS],               name: "IX_EC_STATUS")
  @@map("EDUCATION_COURSE")
}